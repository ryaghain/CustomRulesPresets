{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "dotnet",
			"task": "build",
			"group": "build",
			"problemMatcher": [],
			"label": "dotnet: build"
		},
		{
			"label": "extract zip",
			"type": "process",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"Expand-Archive -LiteralPath '${workspaceFolder}\\artifacts\\thunderstore\\ryaghain-CustomRulesPresets-0.1.0.zip' -DestinationPath 'C:\\Users\\ryan\\AppData\\Roaming\\com.kesomannen.gale\\super-battle-golf\\profiles\\ModDev\\BepInEx\\plugins\\CustomRulesPresets' -Force"
			],
			"problemMatcher": []
		},
		{
			"label": "dotnet build Release",
			"type": "process",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/CustomRulesPresets.slnx",
				"-c",
				"Release",
				"/property:GenerateFullPaths=true",
				"/p:Platform=Any CPU",
				"/consoleloggerparameters:NoSummary"
			],
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"problemMatcher": "$msCompile"
		},
		{
			"label": "build then extract",
			"dependsOrder": "sequence",
			"dependsOn": [
				"dotnet build Release",
				"extract zip"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": []
		}
	]
}