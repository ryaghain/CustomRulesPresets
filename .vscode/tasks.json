{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "dotnet",
			"task": "build",
			"group": "build",
			"problemMatcher": [],
			"label": "dotnet: build"
		},
		{
			"label": "dotnet build Release",
			"type": "process",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/CustomRulesPresets.slnx",
				"-c",
				"Release",
				"/property:GenerateFullPaths=true",
				"/p:Platform=Any CPU",
				"/consoleloggerparameters:NoSummary"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile"
		}
	]
}